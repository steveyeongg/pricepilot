# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pricepilot
# Supabase example: postgresql+asyncpg://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Redis cache (Upstash)
REDIS_URL=redis://default:password@host.upstash.io:6379
# Leave empty to disable caching in dev
# REDIS_URL=

# App settings
APP_ENV=development
SECRET_KEY=change-this-to-a-long-random-secret-key
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Scraping settings
SCRAPE_REQUEST_DELAY_MS=1500
SCRAPE_MAX_RETRIES=3
SCRAPE_TIMEOUT_SECS=30

# Scheduler
PRICE_CHECK_INTERVAL_MINUTES=60
ALERT_CHECK_INTERVAL_MINUTES=15

# Optional: proxy rotation for scrapers (comma-separated)
# PROXY_LIST=http://user:pass@host1:port,http://user:pass@host2:port

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
